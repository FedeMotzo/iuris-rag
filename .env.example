# LLM provider selection: "anthropic" (default cloud) | "ollama" (locale)
LLM_PROVIDER=anthropic

# Anthropic API (required se LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (locale, fallback / demo offline)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_NUM_CTX=8192

# Pipeline RAG serving (W5)
RAG_TOP_K=5
RAG_RERANK_TOP_K=20
RAG_USE_GRAPH=false
# 1000 token = alzato da 500 dopo smoke cloud 2026-05-19 (Sonnet 4.6
# troncava 3/3 query a 500 mid-frase). Vedi PROJECT_CONTEXT.md.
RAG_MAX_OUTPUT_TOKENS=1000
